# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Maps Distance Matrix API — https://console.cloud.google.com
# Enable "Distance Matrix API" and restrict key to that API only
GOOGLE_MAPS_API_KEY=

# Warehouse origin address used for travel-time lookup
WAREHOUSE_ADDRESS=10525 S Ridgeland Ave, Alsip, IL 60803

# Vercel KV (Upstash Redis) — auto-injected by Vercel when KV is connected
# For local dev: `vercel env pull .env.local`
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# SendGrid — admin notifications when contact form / chatbot booking is submitted
# SENDGRID_FROM_EMAIL must be a verified sender in SendGrid.
# Defaults if blank: from=info@windycityicecream.com, to=elena@windycityicecream.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
ADMIN_EMAIL=
